{
  "name": "@tanqory/mies-icons",
  "version": "0.1.0",
  "description": "Tanqory Mies Icon Library - Cross-platform icons for Web & Mobile",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./web": {
      "types": "./dist/web.d.ts",
      "import": "./dist/web.js"
    },
    "./native": {
      "types": "./dist/native.d.ts",
      "import": "./dist/native.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist *.tsbuildinfo",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "echo 'No tests yet' && exit 0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.75.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "react-native": "^0.75.0",
    "react-native-svg": "^15.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}