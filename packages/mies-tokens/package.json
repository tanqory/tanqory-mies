{
  "name": "@tanqory/mies-tokens",
  "version": "0.1.0",
  "description": "Tanqory Mies Design Tokens - Cross-platform design system tokens",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./dist/tokens.css",
    "./tokens": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./json": "./dist/tokens.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && cp src/tokens.css dist/ && cp src/tokens.json dist/",
    "clean": "rm -rf dist *.tsbuildinfo",
    "dev": "tsup --watch",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "echo 'No tests yet' && exit 0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}